# .env.example — Template public pour les clés d'API
# Copie ce fichier en .env et remplis tes vraies valeurs
# Le fichier .env est dans .gitignore et ne sera jamais sauvegardé automatiquement

# IA
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Automatisation
MAKE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ZAPIER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Communication
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ajoute tes clés ici selon les outils que tu utilises
# Format : NOM_OUTIL_API_KEY=valeur
